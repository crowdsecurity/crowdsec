<!DOCTYPE html>
<html lang="en">
  <head>
    <title>CrowdSec Challenge</title>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --bg: #f8fafc;
        --card-bg: #ffffff;
        --card-border: #e2e8f0;
        --text: #1e293b;
        --text-secondary: #475569;
        --text-muted: #94a3b8;
        --coin-front: linear-gradient(145deg, #e2e8f0, #cbd5e1);
        --coin-back: linear-gradient(145deg, #ede9fe, #c4b5fd);
        --coin-shadow: rgba(0,0,0,0.12);
        --success: #16a34a;
        --error: #dc2626;
        --modal-overlay: rgba(0,0,0,0.5);
        --modal-bg: #ffffff;
        --btn-bg: rgba(255,255,255,0.9);
        --btn-border: #cbd5e1;
      }

      @media (prefers-color-scheme: dark) {
        :root {
          --bg: #0f172a;
          --card-bg: #1e293b;
          --card-border: #334155;
          --text: #f1f5f9;
          --text-secondary: #cbd5e1;
          --text-muted: #64748b;
          --coin-front: linear-gradient(145deg, #334155, #1e293b);
          --coin-back: linear-gradient(145deg, #3b0764, #4c1d95);
          --coin-shadow: rgba(0,0,0,0.3);
          --success: #22c55e;
          --error: #f87171;
          --modal-overlay: rgba(0,0,0,0.7);
          --modal-bg: #1e293b;
          --btn-bg: rgba(30,41,59,0.9);
          --btn-border: #475569;
        }
      }

      html, body {
        height: 100%;
        width: 100%;
        font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
        background: var(--bg);
        color: var(--text);
      }

      body {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
      }

      #challenge-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 28px;
        padding: 40px 32px 32px;
        border: 1px solid var(--card-border);
        border-radius: 16px;
        background: var(--card-bg);
        width: min(440px, 90vw);
        box-shadow: 0 4px 24px rgba(0,0,0,0.06);
      }

      #challenge-header {
        text-align: center;
      }

      #challenge-header h1 {
        font-size: 20px;
        font-weight: 600;
        color: var(--text);
        margin-bottom: 4px;
      }

      #challenge-header p {
        font-size: 13px;
        color: var(--text-muted);
      }

      /* ── Coin ── */
      #coin-wrapper {
        perspective: 800px;
        width: 130px;
        height: 130px;
      }

      #coin {
        width: 100%;
        height: 100%;
        position: relative;
        transform-style: preserve-3d;
      }

      #coin.flipping {
        animation: coin-flip 1.8s cubic-bezier(0.4, 0, 0.2, 1) infinite;
      }

      @keyframes coin-flip {
        0%   { transform: rotateY(0deg); }
        100% { transform: rotateY(360deg); }
      }

      #coin-front, #coin-back {
        position: absolute;
        inset: 0;
        backface-visibility: hidden;
        -webkit-backface-visibility: hidden;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 2px 12px var(--coin-shadow), inset 0 0 0 2px rgba(128,128,128,0.1);
        overflow: hidden;
      }

      #coin-front {
        background: var(--coin-front);
        transform: rotateY(0deg);
      }

      #coin-back {
        background: var(--coin-back);
        transform: rotateY(180deg);
      }

      #coin-back img {
        width: 85%;
        height: 85%;
        object-fit: contain;
      }

      /* Status: success → settle on alpaca (back) */
      #coin.success {
        animation: coin-to-back 0.8s cubic-bezier(0.22, 1, 0.36, 1) forwards;
      }
      @keyframes coin-to-back {
        0%   { transform: rotateY(0deg); }
        100% { transform: rotateY(180deg); }
      }
      #coin.success #coin-back {
        box-shadow: 0 0 24px rgba(22,163,74,0.45), 0 0 48px rgba(22,163,74,0.15), inset 0 0 0 2px rgba(22,163,74,0.25);
      }

      /* Status: fail → settle on robot (front) */
      #coin.fail {
        animation: coin-to-front 0.6s cubic-bezier(0.22, 1, 0.36, 1) forwards;
      }
      @keyframes coin-to-front {
        0%   { transform: rotateY(90deg); }
        100% { transform: rotateY(0deg); }
      }
      #coin.fail #coin-front {
        box-shadow: 0 0 24px rgba(220,38,38,0.45), 0 0 48px rgba(220,38,38,0.15), inset 0 0 0 2px rgba(220,38,38,0.25);
      }

      /* Reduced motion */
      @media (prefers-reduced-motion: reduce) {
        #coin.flipping { animation-duration: 0.01ms; animation-iteration-count: 1; }
      }

      /* ── Status text ── */
      #status-area {
        text-align: center;
        min-height: 48px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 4px;
      }

      #challenge-status-text {
        font-size: 16px;
        font-weight: 500;
        color: var(--text-secondary);
        transition: color 0.3s;
      }

      #challenge-status-sub {
        font-size: 13px;
        color: var(--text-muted);
      }

      /* ── Footer ── */
      #challenge-footer {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 12px;
        color: var(--text-muted);
      }

      #challenge-footer a {
        display: flex;
        align-items: center;
        gap: 4px;
        color: var(--text-muted);
        text-decoration: none;
        font-weight: 500;
      }
      #challenge-footer a:hover { text-decoration: underline; }

      #challenge-footer svg { fill: currentColor; }

      /* ── Help button & modal ── */
      #challenge-help-open {
        position: fixed;
        bottom: 16px;
        left: 50%;
        transform: translateX(-50%);
        z-index: 1000;
        border: 1px solid var(--btn-border);
        border-radius: 9999px;
        padding: 7px 14px;
        background: var(--btn-bg);
        color: var(--text-secondary);
        font-size: 13px;
        line-height: 1.2;
        cursor: pointer;
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
      }

      #challenge-help-modal {
        display: none;
        position: fixed;
        inset: 0;
        z-index: 1001;
        background: var(--modal-overlay);
        align-items: center;
        justify-content: center;
        padding: 16px;
      }

      #challenge-help-dialog {
        width: min(520px, 100%);
        border-radius: 12px;
        border: 1px solid var(--card-border);
        background: var(--modal-bg);
        color: var(--text);
        padding: 20px;
        box-shadow: 0 25px 50px rgba(0,0,0,0.25);
      }

      .modal-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
      }

      .modal-header h2 { font-size: 18px; font-weight: 600; }

      .modal-close {
        border: 1px solid var(--btn-border);
        border-radius: 6px;
        padding: 4px 10px;
        font-size: 14px;
        cursor: pointer;
        background: transparent;
        color: var(--text);
      }

      .modal-body {
        margin-top: 14px;
        font-size: 14px;
        line-height: 1.6;
        color: var(--text-secondary);
      }
      .modal-body p + p { margin-top: 8px; }
    </style>
  </head>

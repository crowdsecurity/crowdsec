    <script>
      (() => {
        const coin = document.getElementById("coin");
        const statusText = document.getElementById("challenge-status-text");
        const statusSub = document.getElementById("challenge-status-sub");
        const openBtn = document.getElementById("challenge-help-open");
        const closeBtn = document.getElementById("challenge-help-close");
        const modal = document.getElementById("challenge-help-modal");
        let reloadTriggered = false;
        let dotsInterval = null;

        function startDots() {
          if (dotsInterval) return;
          let n = 0;
          dotsInterval = setInterval(() => {
            n = (n + 1) % 4;
            if (statusText) statusText.textContent = "Consulting the crowd" + ".".repeat(n);
          }, 450);
        }

        function stopDots() {
          if (dotsInterval) { clearInterval(dotsInterval); dotsInterval = null; }
        }

        function setChallengeStatus(status) {
          if (!coin || !statusText) return;
          const s = typeof status === "string" ? status.toLowerCase() : "pending";

          if (s === "pending" || s === "") {
            coin.className = "flipping";
            startDots();
            if (statusSub) statusSub.textContent = "Your browser is being verified";
            return;
          }

          if (s === "ok" || s === "success") {
            stopDots();
            coin.className = "success";
            statusText.textContent = "Verification successful";
            statusText.style.color = "var(--success)";
            if (statusSub) statusSub.textContent = "Redirecting\u2026";
            if (!reloadTriggered) {
              reloadTriggered = true;
              setTimeout(() => { window.location.reload(); }, 800);
            }
            return;
          }

          if (s === "fail" || s === "failed" || s === "error") {
            stopDots();
            coin.className = "fail";
            statusText.textContent = "Verification failed";
            statusText.style.color = "var(--error)";
            if (statusSub) statusSub.textContent = "Please try again";
          }
        }

        window.addEventListener("crowdsec-challenge-status", (event) => {
          setChallengeStatus(event?.detail?.status);
        });
        setChallengeStatus(window.__crowdsecChallengeStatus);

        if (!openBtn || !closeBtn || !modal) return;

        const showModal = () => { modal.style.display = "flex"; modal.setAttribute("aria-hidden", "false"); };
        const hideModal = () => { modal.style.display = "none"; modal.setAttribute("aria-hidden", "true"); };

        openBtn.addEventListener("click", showModal);
        closeBtn.addEventListener("click", hideModal);
        modal.addEventListener("click", (e) => { if (e.target === modal) hideModal(); });
        document.addEventListener("keydown", (e) => { if (e.key === "Escape") hideModal(); });
      })();
    </script>
  </body>
</html>

    <script>
      (() => {
        window.__crowdsecChallengeStatus = "pending";

        window.crowdsecSetChallengeStatus = (status) => {
          if (typeof status !== "string") {
            return;
          }
          window.__crowdsecChallengeStatus = status;
          window.dispatchEvent(
            new CustomEvent("crowdsec-challenge-status", {
              detail: { status },
            }),
          );
        };

        window.addEventListener("crowdsec-challenge-status", (event) => {
          const status = event?.detail?.status;
          if (typeof status === "string") {
            window.__crowdsecChallengeStatus = status;
          }
        });
      })();
    </script>

